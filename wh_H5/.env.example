# ====================
# 后端服务器配置
# ====================

# 服务器端口
PORT=8181

# 运行环境 (development / production)
NODE_ENV=development

# ====================
# 数据库配置
# ====================

# 数据库连接信息
DB_HOST=47.98.100.22
DB_PORT=3306
DB_USER=root
DB_PASS=your_password_here
DB_NAME=topic_mall

# 数据库连接池配置（可选，不配置则使用默认值）
DB_CONNECTION_LIMIT=30          # 连接数限制（默认 30）
DB_QUEUE_LIMIT=50               # 队列限制（默认 50）
DB_ACQUIRE_TIMEOUT=60000        # 获取连接超时（毫秒，默认 60 秒）
DB_KEEPALIVE_DELAY=10000        # KeepAlive 延迟（毫秒，默认 10 秒）

# SSL 配置（可选）
DB_SSL=false
DB_TLS=false
DB_SSL_REJECT_UNAUTHORIZED=true

# 连接超时（毫秒）
DB_CONNECT_TIMEOUT=2000

# ====================
# 飞书多维表格配置（可选）
# ====================

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_COURSES_TABLE_ID=
FEISHU_BITABLE_PROJECTS_TABLE_ID=

# 飞书分页大小
FEISHU_PAGE_SIZE=100

# ====================
# 请求限流配置（可选）
# ====================

# 是否启用限流
RATE_LIMIT_ENABLED=true

# 时间窗口（毫秒）
RATE_LIMIT_WINDOW_MS=900000     # 15 分钟

# 最大请求数
RATE_LIMIT_MAX_REQUESTS=1000    # 15 分钟内最多 1000 次

# ====================
# API 配置
# ====================

# API 基础路径
API_BASE_URL=/api

# ====================
# 日志配置
# ====================

# 日志级别 (error / warn / info / debug)
LOG_LEVEL=info

# 日志目录
LOG_DIR=logs
